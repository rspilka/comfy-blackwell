    {
      "title": "GPU Temperatur",
      "type": "gauge",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 13
      },
      "targets": [
        {
          "expr": "nvidia_smi_temperature_gpu",
